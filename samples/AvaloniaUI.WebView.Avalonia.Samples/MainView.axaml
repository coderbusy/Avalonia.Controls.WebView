<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:webView="clr-namespace:AvaloniaUI.WebView;assembly=AvaloniaUI.WebView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaloniaUI.WebView.Avalonia.Samples.MainView"
             KeyDown="Window_OnKeyDown"
             KeyUp="Window_OnKeyUp">
    <TabControl>
        <TabItem Header="AvaloniaUI">
            <Grid RowDefinitions="3*, *">
                <webView:NativeWebView Source="https://google.com/"
                                       NavigationCompleted="NativeWebView_OnNavigationCompleted"
                                       NavigationStarted="NativeWebView_OnNavigationStarted"
                                       WebMessageReceived="NativeWebView_OnWebMessageReceived"
                                       KeyDown="InputElement_OnKeyDown"
                                       KeyUp="InputElement_OnKeyUp"/>
                <TextBox IsReadOnly="True" Grid.Row="1" x:Name="LogList" />
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>

